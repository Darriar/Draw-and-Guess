<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="700.0" minWidth="1000.0" prefHeight="800.0" prefWidth="1200.0" styleClass="root-pane" stylesheets="@draw_style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.darya.gamedrawandguess.ui.DrawController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <top>
        <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="timerLabel" styleClass="timer-badge" text="00:34" />
                <Label fx:id="statusLabel" styleClass="hint-label" text="Подсказка: Напиток" />
            </children>
            <padding>
                <Insets bottom="20.0" />
            </padding>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="220.0" spacing="20.0" styleClass="side-card">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <BorderPane.margin>
                <Insets right="20.0" />
            </BorderPane.margin>

            <children>
                <StackPane VBox.vgrow="ALWAYS">
                    <children>
                        <VBox fx:id="toolsPane" spacing="15.0">
                            <children>
                                <Label styleClass="small-header" text="ИНСТРУМЕНТЫ" />
                                <VBox fx:id="toolsVBox" alignment="TOP_CENTER" spacing="12.0" />
                            </children>
                        </VBox>

                        <VBox fx:id="playersPane" managed="false" spacing="15.0" visible="false" VBox.vgrow="ALWAYS">
                            <children>
                                <Label styleClass="small-header" text="ИГРОКИ" />

                                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="no-border-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS"> <content>
                                    <VBox fx:id="playersVBox" spacing="8.0" />
                                </content>
                                </ScrollPane>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" BorderPane.alignment="CENTER">
            <children>
                <StackPane fx:id="canvasContainer" styleClass="canvas-card" VBox.vgrow="ALWAYS">
                    <children>
                        <Canvas fx:id="gameCanvas" height="500.0" width="700.0" />
                        <Canvas fx:id="tempCanvas" height="500.0" width="700.0" />
                    </children>
                </StackPane>

                <HBox fx:id="bottomHBox" alignment="CENTER" prefHeight="80.0" spacing="25.0" styleClass="bottom-card">
                    <children>
                        <ColorPicker fx:id="colorPicker" styleClass="modern-picker" />
                        <Separator orientation="VERTICAL" />
                        <VBox alignment="CENTER" spacing="5.0">
                            <children>
                                <Label style="-fx-font-size: 11; -fx-text-fill: #888;" text="Размер кисти" />
                                <Slider fx:id="sizeSlider" prefWidth="150.0" />
                            </children>
                        </VBox>
                        <Separator orientation="VERTICAL" />
                        <Button fx:id="clearBtn" onAction="#clearCanvas" styleClass="clear-btn" text="Очистить" />
                    </children>
                    <padding>
                        <Insets left="20.0" right="20.0" />
                    </padding>
                </HBox>
            </children>
        </VBox>
    </center>

    <right>
        <VBox prefWidth="280.0" spacing="20.0" BorderPane.alignment="CENTER">
            <children>

                <VBox spacing="10.0" styleClass="side-card" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="small-header" text="ЧАТ" />
                        <TextArea fx:id="chatTextArea" editable="false" styleClass="chat-area" wrapText="true" VBox.vgrow="ALWAYS" />
                        <HBox spacing="5.0">
                            <children>
                                <TextField fx:id="messageTextField" onAction="#onSendBtnClick" promptText="Ваш ответ..." styleClass="modern-field" HBox.hgrow="ALWAYS" />
                                <Button fx:id="sendBtn" onAction="#onSendBtnClick" styleClass="send-btn" text="➤" />
                            </children>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                </VBox>
            </children>
            <BorderPane.margin>
                <Insets left="20.0" />
            </BorderPane.margin>
        </VBox>
    </right>
</BorderPane>
