<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="466.0" prefWidth="620.0" styleClass="root-pane" stylesheets="@welcome_style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.darya.gamedrawandguess.ui.WelcomeController">
   <children>
      <VBox alignment="CENTER" maxHeight="350.0" maxWidth="350.0" spacing="20.0" styleClass="main-container">
         <children>
            <Label styleClass="title-label" text="Вход в игру" />

            <TextField fx:id="inputNameText" onAction="#onStartBtnClick" prefHeight="45.0" promptText="Введите ваш никнейм" styleClass="custom-text-field" />

            <Button fx:id="startBtn" focusTraversable="false" mnemonicParsing="false" onAction="#onStartBtnClick" prefHeight="50.0" prefWidth="180.0" styleClass="main-button" text="Играть" />
         </children>
      </VBox>
   </children>
</StackPane>
